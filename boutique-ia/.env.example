# --- Supabase (copie depuis nebula-prospector/.env si tu réutilises le même projet) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (pour l'étage 2, pas obligatoire pour l'étage 1) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Alertes Telegram vers Mongazi (réutilise le bot NOVA) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_MONGAZI=

# --- Abonnement : comment le commerçant te paie pour activer ---
SAAS_PRICE_FCFA=5000
SAAS_MOMO_NUMBER=
SAAS_MOMO_NAME=NEBULA Agency
SAAS_MOMO_NETWORK=MTN / Moov

# --- WhatsApp PRODUCTION (Meta Cloud API) — dormant tant que vide ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=          # optionnel (signature des webhooks)
# WHATSAPP_GRAPH_VERSION=v21.0

# --- Messenger + Instagram Direct (inbound) — dormant tant que vide ---
# Un seul Page Access Token couvre Messenger ET Instagram (IG rattaché à la Page).
MESSENGER_PAGE_TOKEN=
# MESSENGER_VERIFY_TOKEN=       # sinon retombe sur WHATSAPP_VERIFY_TOKEN

# --- Sécurité ---
ADMIN_TOKEN=change-moi

ENV=development
