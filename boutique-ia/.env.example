# --- Supabase (copie depuis nebula-prospector/.env si tu réutilises le même projet) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (pour l'étage 2, pas obligatoire pour l'étage 1) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Alertes Telegram vers Mongazi (réutilise le bot NOVA) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_MONGAZI=

# --- Abonnement : comment le commerçant te paie pour activer ---
SAAS_PRICE_FCFA=5000
SAAS_MOMO_NUMBER=
SAAS_MOMO_NAME=NEBULA Agency
SAAS_MOMO_NETWORK=MTN / Moov

# --- Sécurité ---
ADMIN_TOKEN=change-moi

ENV=development
