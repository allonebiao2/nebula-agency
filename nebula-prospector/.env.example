# ============================================================
# NEBULA PROSPECTOR — Configuration
# Copie ce fichier vers .env et remplis avec tes vraies clés.
# NE COMMIT JAMAIS LE FICHIER .env
# ============================================================

# --- VAGUE 1 (sourcing) ---

# Supabase : supabase.com → New project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
# anon key : exposée au navigateur (dashboard) — safe car RLS active sur agent_*
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Anthropic : console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# Google Maps : console.cloud.google.com
# → Active "Places API (New)" + "Geocoding API"
# → APIs & Services → Credentials → Create API key
# → Restreindre la clé aux 2 APIs ci-dessus
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXX

# --- VAGUE 2 (enrichissement emails) ---

# Hunter.io : hunter.io → Settings → API
HUNTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxx

# --- VAGUE 3 (envoi email) ---

# Resend : resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Le domaine doit être validé dans Resend (DNS SPF/DKIM)
EMAIL_FROM_ADDRESS=contact@nebula-agency.com
EMAIL_FROM_NAME=Mongazi · NEBULA Agency
EMAIL_REPLY_TO=mongazi@nebula-agency.com

# --- VAGUE 4 (réception emails) ---

# IMAP pour poller les réponses (compte qui reçoit les replies)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=mongazi@nebula-agency.com
IMAP_PASSWORD=xxxxxxxxxxxx   # mot de passe d'application

# --- VAGUE 5 (alertes + dashboard) ---

# Telegram Bot : @BotFather sur Telegram → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCDEF...
# Ton chat ID perso (écris à @userinfobot sur Telegram pour l'obtenir)
TELEGRAM_CHAT_ID_MONGAZI=123456789

# --- Paramètres opérationnels ---

# Limites pour ne pas se faire bannir
MAX_EMAILS_PER_DAY=25
MIN_DELAY_BETWEEN_EMAILS_SECONDS=120
SOURCING_MAX_RESULTS_PER_QUERY=60

# Cibles géographiques (codes pays séparés par virgule)
TARGET_COUNTRIES=BJ,TG,CI,SN,BF
# Villes principales à scanner en priorité
TARGET_CITIES=Cotonou,Lomé,Abidjan,Dakar,Ouagadougou,Porto-Novo,Parakou

# Modèles Claude utilisés
CLAUDE_MODEL_FAST=claude-sonnet-4-6
CLAUDE_MODEL_DEEP=claude-opus-4-7

# Environment
ENV=development  # development | production
LOG_LEVEL=INFO
